# ── LLM API Keys ──────────────────────────────────────────────────
# Set the key for whichever provider you use for evaluation/distillation.
# Only one provider is needed at a time.

# OpenAI (for gpt-4.1, gpt-4o-mini)
OPENAI_API_KEY=

# Anthropic (for claude-sonnet)
ANTHROPIC_API_KEY=

# ── Hugging Face (for downloading benchmark data) ────────────────
# Required only if the TAO Challenge dataset is gated/private.
# Get a read token from: https://huggingface.co/settings/tokens
HF_TOKEN=
